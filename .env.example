# =============================================================================
# Aaron Music Agent 环境配置
# =============================================================================

# AI 接入方式（三选一）：
#
# 方式1: Claude Code CLI（推荐，使用 Max 订阅）
# - 系统会自动检测 `claude` 或 `mc --code` 命令
# - 如果你有自定义代理命令，可设置 CLAUDE_CLI_COMMAND
# - 无需填写下方的 API Key
#
# 方式2: 自定义 CLI 命令（高级用户）
# - 设置 CLAUDE_CLI_COMMAND 来使用代理命令
# - 例如: mc --code, claude-macos 等
#
# 方式3: Anthropic API（需要 API Key）
# - 如果没有 Max 订阅，需要填写下方的 CLAUDE_API_KEY
# - 从 https://console.anthropic.com/ 获取 API Key
# =============================================================================

# 自定义 Claude CLI 命令（可选）
# 如果使用了代理工具（如 mc --code），请取消下方注释并配置
# CLAUDE_CLI_COMMAND=mc --code

# Token 每日限制（可选）
# 默认不限制，如需限制请设置具体数值（如 50000）
# CLAUDE_TOKEN_DAILY_LIMIT=50000

# Anthropic API Key（可选，如果没有 Max 订阅则必填）
CLAUDE_API_KEY=your_claude_api_key_here

# Claude 模型选择（API 模式时使用）
CLAUDE_MODEL=claude-sonnet-4-6
# 可选: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5

# =============================================================================
# 服务器配置
# =============================================================================

# 服务器端口
PORT=8080

# 环境模式: development | production
NODE_ENV=development

# =============================================================================
# 可选配置（功能增强）
# =============================================================================

# 天气 API Key（用于基于天气推荐音乐）
# 从 https://openweathermap.org/api 或类似服务获取
WEATHER_API_KEY=

# TTS (文字转语音) 配置
TTS_ENABLED=false
TTS_PROVIDER=fish
FISH_API_KEY=

# =============================================================================
# 网易云音乐 API 配置
# =============================================================================

# 方式1: 使用本地部署的 API（默认）
# 先运行: npm run start:netease-api 启动本地服务
NETEASE_API_HOST=127.0.0.1
NETEASE_API_PORT=3000

# 方式2: 指定外部 API 地址（适合自定义部署）
# 取消下方注释并修改为你的 API 地址
# NETEASE_API_BASE=https://your-netease-api.com

# 注意: 系统只使用配置的 API，不会自动回退
